# ⚠️ このファイルをコピーして使用します
# cp wrangler.toml.example wrangler.toml.development  # 開発用
# cp wrangler.toml.example wrangler.toml.production   # 本番用

# ⚠️ name をアプリ名に変更してください（例: my-saas-app）
name = "my-app"
compatibility_date = "2026-06-21"
compatibility_flags = ["nodejs_compat"]
pages_build_output_dir = ".vercel/output/static"

# WARNING: wrangler実行時は.envが読まれない場合があります。本番環境変数はCloudflareダッシュボードで設定してください。
[vars]

[[d1_databases]]
binding = "DB"
# ⚠️ Cloudflareダッシュボードで作成したD1 DB名に変更してください
database_name = "my-app-db"
# ローカル開発用: "DB" または任意の文字列（空文字はエラーになります）
# 本番用: Cloudflareダッシュボードで確認できるdatabase_idを設定してください
database_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
preview_database_id = "DB"
migrations_dir = "migrations"
